{
  "name": "@elwood-lang/xlsx",
  "version": "0.7.3",
  "description": "XLSX (Excel) format support for the Elwood JSON transformation DSL. Optional extension — install only if you need Excel I/O.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@elwood-lang/core": ">=0.2.0"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@elwood-lang/core": "file:../ts",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "license": "MIT",
  "author": "Massimiliano Favilli",
  "keywords": ["json", "elwood", "xlsx", "excel", "transform"]
}
