{
  inner: $.orders[*]
    | join $.customers[*] on o => o.customerId equals c => c.id into cust inner
    | select r => { order: r.id, customer: r.cust.name },
  left: $.orders[*]
    | join $.customers[*] on o => o.customerId equals c => c.id into cust left
    | select r => { order: r.id, customer: r.cust.name },
  right: $.orders[*]
    | join $.customers[*] on o => o.customerId equals c => c.id into cust right
    | select r => { order: r.id, customer: r.cust.name },
  full: $.orders[*]
    | join $.customers[*] on o => o.customerId equals c => c.id into cust full
    | select r => { order: r.id, customer: r.cust.name }
}